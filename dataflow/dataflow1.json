{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "filter1"
				},
				{
					"name": "sort1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     paramestr_ter1 as string",
				"}",
				"source(allowSchemaDrift: true,",
				"     validateSchema: false) ~> source1",
				"sort1 filter(ERROR_FUNCTION('')) ~> filter1",
				"source1 sort(asc(ERROR_FUNCTION(''), true)) ~> sort1",
				"filter1 derive(column1 = ERROR_FUNCTION(''),",
				"          each(match(lower(\r",
				"    replace(\r",
				"        replace(\r",
				"            replace($$, ' ', '_'),\r",
				"        '-', '_'),\r",
				"    '[^A-Za-z0-9_]', '')\r",
				")), ERROR_FUNCTION('') = ERROR_FUNCTION(''))) ~> derivedColumn1",
				"derivedColumn1 select(skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1"
			]
		}
	}
}